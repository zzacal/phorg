<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Phorg.Avalonia.ViewModels"
        x:Class="Phorg.Avalonia.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Phorg"
        Width="700" Height="600"
        MinWidth="500" MinHeight="400">

  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="16">

    <!-- Row 0: Browse Source -->
    <Button  Grid.Row="0" Grid.Column="0" Content="Browse Source" Command="{Binding BrowseSourceCommand}"
             HorizontalAlignment="Stretch" Margin="0,0,12,8"/>
    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SourcePath}" IsReadOnly="True"
             PlaceholderText="Source folder" Margin="0,0,0,8"/>

    <!-- Row 1: Browse Dest -->
    <Button  Grid.Row="1" Grid.Column="0" Content="Browse Dest" Command="{Binding BrowseDestCommand}"
             HorizontalAlignment="Stretch" Margin="0,0,12,8"/>
    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DestPath}" IsReadOnly="True"
             PlaceholderText="Destination folder" Margin="0,0,0,8"/>

    <!-- Row 2: Scan -->
    <Button  Grid.Row="2" Grid.Column="0" Content="Scan" Command="{Binding ScanCommand}"
             HorizontalAlignment="Stretch" Margin="0,0,12,12"/>

    <!-- Row 3: Date groups (fills remaining space) -->
    <ScrollViewer Grid.Row="3" Grid.Column="1">
      <ItemsControl ItemsSource="{Binding DateGroups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DateGroupViewModel">
            <StackPanel Margin="0,4,0,8">

              <Grid ColumnDefinitions="120,Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding DateKey}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding FileCount, StringFormat='{}{0} files'}"
                           VerticalAlignment="Center" Margin="8,0" Foreground="Gray"/>
                <TextBox   Grid.Column="2" Text="{Binding Suffix}" PlaceholderText="Suffix (optional)"/>
              </Grid>

              <!-- Film strip -->
              <Border Background="#1a1a1a" IsVisible="{Binding HasPreviews}"
                      Margin="0,6,0,0" CornerRadius="3" ClipToBounds="True">
                <Grid RowDefinitions="12,Auto,12">

                  <!-- Top sprocket strip -->
                  <Border Grid.Row="0" Background="#2a2a2a"/>

                  <!-- Scrollable images -->
                  <ScrollViewer Grid.Row="1"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Previews}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="2"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Image Source="{Binding}" Height="80" Width="110" Stretch="UniformToFill"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <!-- Bottom sprocket strip -->
                  <Border Grid.Row="2" Background="#2a2a2a"/>

                </Grid>
              </Border>

            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Row 4: Copy Files + counter -->
    <Button    Grid.Row="4" Grid.Column="0" Content="Copy Files" Command="{Binding StartCopyCommand}"
               HorizontalAlignment="Stretch" Margin="0,12,12,0"/>
    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CopiedCount, StringFormat='Copied: {0}'}"
               VerticalAlignment="Center" Margin="0,12,0,0"/>

    <!-- Row 5: Progress -->
    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                IsVisible="{Binding HasProgress}" Margin="0,8,0,0" Spacing="4">
      <ProgressBar Minimum="0" Maximum="{Binding TotalCount}"
                   Value="{Binding CopiedCount}"
                   IsIndeterminate="{Binding IsScanning}"
                   ShowProgressText="True"
                   Height="24"/>
      <TextBlock Text="{Binding LastCopiedFile}"
                 IsVisible="{Binding IsCopying}"
                 FontFamily="Monospace" FontSize="11"
                 TextTrimming="CharacterEllipsis"/>
    </StackPanel>

  </Grid>
</Window>
